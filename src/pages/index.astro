---
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import "@fancyapps/ui/dist/fancybox/fancybox.css";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../images/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}",
);
---

<BaseLayout
  title="Happy Birthday, I love you!"
  description="A small birthday gallery for a very special person."
>
  <section class="hero">
    <p class="eyebrow">To my favorite person, my dear Riccarda</p>
    <h1>Happy Birthday, I love you!</h1>
    <p class="lede">
      A little gallery of us. I love you so much and all the joy you bring into
      my life every day. We've faced so much, but I hope we never stop choosing
      each other. 🖤
    </p>
  </section>

  <section class="justified-gallery" aria-label="Birthday photo gallery">
    {
      Object.entries(images).map(async ([_path, image], index) => {
        const { default: imageData } = await image();
        return (
          <a
            style={`--width: ${imageData.width}; --height: ${imageData.height};`}
            href={imageData.src}
            target="_blank"
            data-fancybox="gallery"
          >
            <Image
              format="webp"
              src={imageData}
              alt=""
              height={400}
              loading={index < 20 ? "eager" : "lazy"}
            />
          </a>
        );
      })
    }
  </section>

  <section class="bottom-cta" aria-label="Contact call to action">
    <a
      class="miss-me-button"
      href="https://wa.me/436805066646"
      target="_blank"
      rel="noopener noreferrer"
    >
      Miss me?
    </a>
  </section>
</BaseLayout>

<script>
  import { Fancybox } from "@fancyapps/ui/dist/fancybox/";

  Fancybox.bind("[data-fancybox]", {
    theme: "auto",
    mainStyle: {
      "--f-button-width": "44px",
      "--f-button-height": "44px",
      "--f-button-border-radius": "50%",
      "--f-toolbar-padding": "16px",
    },
    Carousel: {
      Arrows: false,
      Toolbar: {
        display: {
          left: [],
          middle: [],
          right: ["close"],
        },
      },
      transition: "slide",
    },
  });
</script>

<style>
  @font-face {
    font-family: "Raphael";
    src: url("/fonts/raphael.ttf") format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :global(body) {
    background:
      radial-gradient(
        circle at 18% 8%,
        rgba(255, 214, 230, 0.86),
        transparent 38%
      ),
      radial-gradient(
        circle at 82% 22%,
        rgba(218, 186, 200, 0.2),
        transparent 48%
      ),
      linear-gradient(
        180deg,
        #fff7fb 0%,
        #fff3f8 18%,
        #f4e8de 42%,
        #d7c6c4 64%,
        #625463 82%,
        #1e1a28 100%
      );
    color: #24131d;
  }

  .hero {
    padding: clamp(2rem, 6vw, 5rem) clamp(1rem, 4vw, 3rem) 1rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  .eyebrow {
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.75rem;
    font-weight: 700;
    color: #9d496d;
  }

  h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 9vw, 7.5rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    font-weight: 400;
    font-family:
      "Raphael", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
  }

  .lede {
    max-width: 36rem;
    margin-top: 1.25rem;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    color: rgba(36, 19, 29, 0.84);
  }

  .bottom-cta {
    max-width: 88rem;
    margin: 0 auto;
    padding: 0.75rem clamp(1rem, 4vw, 2rem) clamp(2.2rem, 5vw, 3.5rem);
    display: flex;
    justify-content: center;
  }

  .miss-me-button {
    display: inline-flex;
    position: relative;
    isolation: isolate;
    align-items: center;
    justify-content: center;
    margin-top: 0;
    gap: 0.36rem;
    padding: 0.8rem 1.55rem;
    border-radius: 999px;
    border: 1px solid rgba(118, 52, 79, 0.52);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.96) 0%,
        rgba(246, 230, 240, 0.9) 100%
      ),
      radial-gradient(
        circle at 20% 18%,
        rgba(255, 255, 255, 0.9),
        rgba(255, 255, 255, 0) 54%
      );
    color: #54172f;
    font-size: 1.02rem;
    font-weight: 400;
    font-family:
      "Raphael", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.7);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -10px 14px rgba(222, 188, 207, 0.34),
      0 8px 20px rgba(52, 20, 37, 0.16);
    overflow: hidden;
    backdrop-filter: blur(2px);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease,
      color 0.18s ease;
  }

  .miss-me-button::before {
    content: "✶";
    position: absolute;
    left: 0.62rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.7rem;
    color: rgba(165, 108, 136, 0.8);
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.55);
    pointer-events: none;
    z-index: 1;
  }

  .miss-me-button::after {
    content: "✶";
    position: absolute;
    right: 0.62rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.7rem;
    color: rgba(165, 108, 136, 0.8);
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.55);
    opacity: 0.9;
    pointer-events: none;
  }

  .miss-me-button:hover {
    transform: translateY(-2px);
    border-color: rgba(118, 52, 79, 0.75);
    color: #4a1129;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -10px 14px rgba(220, 176, 200, 0.38),
      0 13px 26px rgba(52, 20, 37, 0.22);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.98) 0%,
        rgba(245, 221, 235, 0.95) 100%
      ),
      radial-gradient(
        circle at 20% 18%,
        rgba(255, 255, 255, 0.9),
        rgba(255, 255, 255, 0) 54%
      );
  }

  .miss-me-button:focus-visible {
    outline: 3px solid #9d496d;
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .bottom-cta {
      padding-top: 0.5rem;
      padding-bottom: 2rem;
    }

    .miss-me-button {
      min-height: 44px;
      padding-inline: 1.3rem;
      font-size: 0.98rem;
    }

    .miss-me-button::after {
      right: 0.52rem;
      font-size: 0.66rem;
    }

    .miss-me-button::before {
      left: 0.52rem;
      font-size: 0.66rem;
    }
  }

  .justified-gallery {
    --padding: clamp(1rem, 4vw, 2rem);
    --space: clamp(0.75rem, 2vw, 1.1rem);
    --min-height: clamp(160px, 16vw, 300px);

    padding: var(--padding);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space);
    max-width: 88rem;
    margin: 0 auto;

    a {
      flex-grow: calc(var(--width) * (100000 / var(--height)));
      flex-basis: calc(var(--min-height) * (var(--width) / var(--height)));
      aspect-ratio: var(--width) / var(--height);
      overflow: hidden;
      opacity: 1;
      border-radius: 1rem;
      box-shadow: 0 12px 30px rgba(44, 18, 32, 0.12);
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease,
        opacity 0.18s ease;
    }

    a img {
      display: block;
      object-fit: cover;
      height: 100%;
      width: 100%;
    }

    a:focus-visible {
      outline: 3px solid #9d496d;
      outline-offset: 4px;
      transform: translateY(-2px) scale(1.01);
      z-index: 1;
    }

    a:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 40px rgba(44, 18, 32, 0.18);
    }

    a.hidden {
      transition: opacity 0.4s ease-in-out;
      opacity: 0;
    }

    &::after {
      content: " ";
      flex-grow: 1000000000;
    }
  }
</style>
